{
  "name": "red-flag",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run clean && next dev",
    "dev:turbo": "next dev --turbopack",
    "dev:fresh": "npm run clean && next dev",
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true});console.log('removed .next')}catch(e){if(e.code!=='ENOENT')throw e}\"",
