# Copy this file to `.env.local` for local development.
# On Vercel (e.g. red-flag-v2.vercel.app): Project Settings → Environment Variables — add the same keys for Production and Preview.

# Supabase public values (safe for browser exposure)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server-only value (secret: NEVER expose in client)
SUPABASE_SERVICE_ROLE_KEY=

# Optional (only needed if using checkout-evidence route with Stripe)
STRIPE_SECRET_KEY=
