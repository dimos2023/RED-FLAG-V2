# Copy this file to `.env.local` for local development.
# In Vercel, set the same keys in Project Settings -> Environment Variables.

# Supabase public values (safe for browser exposure)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: set to "true" only for offline mock auth without Supabase (omit or false in production).
# NEXT_PUBLIC_AUTH_DEMO=false

# Supabase server-only value (secret: NEVER expose in client)
SUPABASE_SERVICE_ROLE_KEY=

# Optional (only needed if using checkout-evidence route with Stripe)
STRIPE_SECRET_KEY=
